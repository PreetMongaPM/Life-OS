# ── MongoDB ──────────────────────────────────────────────────────
# MongoDB Atlas connection string (replace with your own cluster URI)
# Leave as localhost to auto-use mongodb-memory-server in development
MONGO_URI=mongodb://localhost:27017/lifeos

# ── JWT ──────────────────────────────────────────────────────────
# A long, random secret string for signing JWTs (min 32 characters)
JWT_SECRET=replace_with_a_strong_random_secret_here

# ── Server ───────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Frontend URL (for CORS in production) ────────────────────────
# Set to your Vercel / frontend domain in production
FRONTEND_URL=http://localhost:5173

# ── Email (optional — for password reset emails) ─────────────────
# If left empty, reset tokens are logged to the console (dev mode)
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_gmail_app_password
